# Host port for nginx HTTP (redirect to HTTPS only). Default 8080; set to 80 if you own that port.
MERIDIAN_HTTP_PORT=8080

# Host port for nginx HTTPS. Default 8443; set to 443 if you own that port.
MERIDIAN_HTTPS_PORT=8443

# Database
DB_NAME=meridian
DB_USERNAME=meridian
DB_PASSWORD=meridian_secret

# JWT — must be ≥32 characters for HMAC-SHA256
JWT_SIGNING_KEY=replace-with-a-secure-random-string-at-least-32-chars

# AES-256 key (32 random bytes, base64-encoded)
# Generate: openssl rand -base64 32
AES_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Local filesystem paths (inside server container)
BACKUP_PATH=/app/backups
EXPORT_PATH=/app/exports

# Require admin approval for data exports (true = all roles including admin must go through workflow)
# Set to false to allow admins to bypass the approval step
EXPORTS_ADMIN_APPROVAL_REQUIRED=true

# Recycle-bin retention in days before hard-delete (default: 14)
RECYCLE_BIN_RETENTION_DAYS=14

# Registration SLA: business days before escalation alert (default: 2)
REGISTRATION_SLA_BUSINESS_DAYS=2
