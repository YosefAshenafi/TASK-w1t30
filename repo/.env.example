# Database
DB_NAME=meridian
DB_USERNAME=meridian
DB_PASSWORD=meridian_secret

# JWT — must be ≥32 characters for HMAC-SHA256
JWT_SIGNING_KEY=replace-with-a-secure-random-string-at-least-32-chars

# AES-256 key (32 random bytes, base64-encoded)
# Generate: openssl rand -base64 32
AES_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Local filesystem paths (inside server container)
BACKUP_PATH=/app/backups
EXPORT_PATH=/app/exports
